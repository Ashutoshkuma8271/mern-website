# Copy to .env.production (or set in CI) before: npm run build
# Your API must be on the public internet with HTTPS (required from https:// pages).
# Example after deploying backend to Render / Railway / Fly.io:
VITE_API_BASE_URL=https://mern-website-1-sg9t.onrender.com
# For Vercel keep root path; only set custom base path for sub-path hosting (e.g. GitHub Pages).
VITE_BASE_PATH=/
